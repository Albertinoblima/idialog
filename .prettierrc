{
    "semi": true,
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "printWidth": 80,
    "bracketSpacing": true,
    "arrowParens": "avoid",
    "endOfLine": "auto",
    "overrides": [
        {
            "files": "*.html",
            "options": {
                "printWidth": 120,
                "tabWidth": 2
            }
        },
        {
            "files": "*.css",
            "options": {
                "printWidth": 100,
                "tabWidth": 2
            }
        }
    ]
}